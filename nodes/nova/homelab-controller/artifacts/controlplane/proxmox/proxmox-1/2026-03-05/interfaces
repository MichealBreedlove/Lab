auto lo
iface lo inet loopback

auto enp2s0
iface enp2s0 inet manual

auto enp3s0
iface enp3s0 inet manual

auto enp4s0
iface enp4s0 inet manual

auto enp5s0
iface enp5s0 inet manual

auto enp6s0
iface enp6s0 inet manual

auto bond0
iface bond0 inet manual
	bond-slaves enp2s0 enp3s0 enp4s0 enp5s0
	bond-miimon 100
	bond-mode 802.3ad
	bond-xmit-hash-policy layer3+4

auto vmbr0
iface vmbr0 inet static
	address 10.1.1.2/24
	gateway 10.1.1.1
	bridge-ports bond0
	bridge-stp off
	bridge-fd 0

auto vmbr1
iface vmbr1 inet static
	address 10.1.1.3/24
	bridge-ports enp6s0
	bridge-stp off
	bridge-fd 0

source /etc/network/interfaces.d/*
