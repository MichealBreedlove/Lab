{
  "enabled": true,
  "allowed_ports": {
    "ssh": 22,
    "openclaw_node": 18789,
    "openclaw_gateway": 18789,
    "prometheus": 9090,
    "grafana": 3000,
    "alertmanager": 9093,
    "loki": 3100,
    "node_exporter": 9100,
    "ollama": 11434,
    "dashboard": 8080
  },
  "ssh_baseline": {
    "permit_root_login": "no",
    "password_authentication": "no",
    "pubkey_authentication": "yes",
    "protocol": 2
  },
  "redaction_patterns": [
    {"name": "aws_key", "regex": "AKIA[0-9A-Z]{16}"},
    {"name": "github_token", "regex": "ghp_[a-zA-Z0-9]{36}"},
    {"name": "openai_key", "regex": "sk-[a-zA-Z0-9]{48}"},
    {"name": "private_key", "regex": "-----BEGIN.*PRIVATE KEY-----"},
    {"name": "password_field", "regex": "(password|passwd|secret|token)[\\s=:]+\\S+"},
    {"name": "bearer_token", "regex": "Bearer\\s+[a-zA-Z0-9._-]{20,}"}
  ],
  "secretscan": {
    "tool": "builtin",
    "block_on_violation": true,
    "allowlist_file": "config/secretscan_allowlist.json"
  },
  "audit_schedule": "weekly"
}
