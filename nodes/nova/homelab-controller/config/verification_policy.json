{
  "enabled": true,
  "synthetic_checks": {
    "interval_seconds": 300,
    "timeout_seconds": 30,
    "checks": [
      {"name": "ssh_nova", "type": "ssh", "host": "10.1.1.21", "user": "micheal", "command": "uptime"},
      {"name": "ssh_mira", "type": "ssh", "host": "10.1.1.22", "user": "micheal", "command": "uptime"},
      {"name": "ssh_orin", "type": "ssh", "host": "10.1.1.23", "user": "micheal", "command": "uptime"},
      {"name": "dns_resolution", "type": "command", "command": "host google.com"},
      {"name": "gateway_ping", "type": "command", "command": "ping -c1 -W5 10.1.1.1"},
      {"name": "dashboard_http", "type": "http", "url": "http://10.1.1.21:8080/", "expect_status": 200}
    ]
  },
  "canary_checks": {
    "enabled": true,
    "checks": [
      {"name": "disk_canary", "type": "file_write", "path": "/tmp/oc_canary_test", "content": "canary_ok"},
      {"name": "dns_canary", "type": "command", "command": "nslookup 10.1.1.1 127.0.0.1 2>/dev/null || echo fail"}
    ]
  },
  "policy_gates": {
    "slo_budget_min_pct": 10,
    "max_open_incidents": 3,
    "dr_readiness_min_score": 60,
    "security_audit_min_score": 60,
    "block_on_failure": true
  },
  "reporting": {
    "output_dir": "artifacts/verification",
    "history_file": "artifacts/verification/history.jsonl",
    "max_history_mb": 10
  }
}
